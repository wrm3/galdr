# ============================================================
# galdr - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
#   copy .env.example .env
# Docker Compose reads this from the project root automatically.
# DO NOT commit .env to version control!
# ============================================================

# ============================================================
# PostgreSQL (Required for RAG)
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=knowledge_base
POSTGRES_USER=knowledge_base
POSTGRES_PASSWORD=CHANGE_ME_use_a_strong_password

# ============================================================
# Video Analyzer Configuration
# ============================================================
# Frame extraction settings
FRAME_INTERVAL=30
MAX_FRAMES=10
PLAYLIST_LIMIT=50

# Note: Video analyzer uses ANTHROPIC_API_KEY for vision analysis
# and OPENAI_API_KEY for embeddings (if RAG integration enabled)

# ============================================================
# Research APIs (Optional — used by research_deep / research_search tools)
# NO DuckDuckGo — uses Perplexity and Google instead
# ============================================================
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
OPENAI_API_KEY=ADD_KEY_HERE
GEMINI_API_KEY=your-gemini-api-key-here
# --- Embeddings ---
# Model used to generate vector embeddings for RAG ingestion and search.
# OpenAI options: text-embedding-3-small (fast/cheap), text-embedding-3-large (best quality)
# text-embedding-ada-002 (legacy)
EMBEDDING_MODEL=text-embedding-3-small
# Embedding vector dimensions (must match your DB schema: vector(N))
# text-embedding-3-small: 1536  |  text-embedding-3-large: 3072  |  ada-002: 1536
EMBEDDING_DIMENSIONS=1536
# Max input characters per chunk sent to the embedding API (keep under model token limit)
EMBEDDING_CHUNK_MAX_CHARS=2000
# Character overlap between adjacent chunks (helps context continuity)
EMBEDDING_CHUNK_OVERLAP=200

# --- Research Summaries (RAG post-processing) ---
# Model used to summarize or enrich crawled content.
# Anthropic options: claude-opus-4-5, claude-sonnet-4-5, claude-haiku-4-5
# Set to empty to disable AI summarization (store raw markdown only)
RESEARCH_MODEL=claude-sonnet-4-6

# --- Video Analysis ---
# Model used for video frame analysis (Vision).
# Anthropic options: claude-opus-4-5, claude-sonnet-4-5, claude-haiku-4-5
VIDEO_ANALYSIS_MODEL=claude-haiku-4-5


# ============================================================
# Platform Documentation Crawler
# Firecrawl has been replaced by crawl4ai (free, open-source).
# Run: python scripts/platform_crawl.py --target all
# No API key needed.
# ============================================================

# ============================================================
# MediaWiki (Optional — runs with: docker compose --profile mediawiki up)
# ============================================================
# --- Service URLs (change per environment: home, work, OKE) ---
# Home:       http://localhost:8880
# Work LAN:   http://192.168.x.x:8880
# OKE/K8s:    https://wiki.your-domain.com
MEDIAWIKI_SERVER=http://localhost:8880

# --- Wiki identity ---
MEDIAWIKI_SITE_NAME=Knowledge Base
MEDIAWIKI_PUBLIC=false

# --- Admin account (created on first install) ---
MEDIAWIKI_ADMIN_USER=WikiAdmin
MEDIAWIKI_ADMIN_PASSWORD=CHANGE_ME_strong_password
MEDIAWIKI_ADMIN_EMAIL=admin@localhost

# --- Database (uses shared Postgres instance — no MySQL needed) ---
MEDIAWIKI_DB_NAME=mediawiki
MEDIAWIKI_DB_PREFIX=mw_

# --- Security keys (REQUIRED — generate with: openssl rand -hex 32) ---
MEDIAWIKI_SECRET_KEY=GENERATE_WITH_openssl_rand_hex_32
MEDIAWIKI_UPGRADE_KEY=GENERATE_WITH_openssl_rand_hex_16

# --- Bot credentials for mediawiki_page / mediawiki_search MCP tools ---
# Create a bot password in MediaWiki: Special:BotPasswords
# Format: WikiAdmin@BotName
MEDIAWIKI_USERNAME=WikiAdmin@galdr_MCP
MEDIAWIKI_PASSWORD=CHANGE_ME_bot_password
MEDIAWIKI_API_KEY=

# ============================================================
# Server Configuration
# ============================================================
# Docker Compose OVERRIDES MCP_TRANSPORT, MCP_HOST, and MCP_PORT
# with container-specific values (streamable-http on 0.0.0.0:8082).
# The values below are only used if running the server outside Docker.
#
# Docker endpoints (what you actually connect to):
#   Main MCP:        http://localhost:8082/mcp
# ============================================================
LOG_LEVEL=INFO
# Local server transport (streamable-http on port 8082)
MCP_TRANSPORT=streamable-http
MCP_HOST=127.0.0.1
MCP_PORT=8082

# ============================================================
# pgAdmin (Optional — database management UI)
# Start with: docker compose --profile admin up
# URL: http://localhost:8083
# Change per environment: home=localhost, work=192.168.x.x, OKE=pgadmin.domain.com
# ============================================================
PGADMIN_URL=http://localhost:8083
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=CHANGE_ME_strong_password

# ============================================================
# Task Visualizer (Docker volume mount)
# ============================================================
# The galdr Docker container mounts your project directory read-only
# for the task visualizer. Set this to your local clone path.
# Default is G:/galdr which only works on the author's machine.
#
# Examples:
#   Windows:  GALDR_PROJECT_HOST_PATH=G:/galdr
#   macOS:    GALDR_PROJECT_HOST_PATH=/Users/you/galdr
#   Linux:    GALDR_PROJECT_HOST_PATH=/home/you/galdr
# ============================================================
GALDR_PROJECT_HOST_PATH=

# ============================================================
# Galdr Vault (File-based knowledge store)
# ============================================================
# DEPRECATED: Vault path is now configured in .galdr/.vault_location
# This variable is kept for backward compatibility only.
# To configure vault path, edit .galdr/.vault_location instead.
#
# .galdr/.vault_location contains a single line:
#   {LOCAL}              — use .galdr/vault/ (default)
#   G:\galdr-vault       — use a shared vault folder
# ============================================================
GALDR_KNOWLEDGE_WELL_PATH=
