# .gald3r/.gitignore — gald3r system local files
# This file is safe to overwrite on upgrades; it covers only the .gald3r/ subtree.

# Hook-generated logs (audit, shell commands, reflection hints)
logs/
*.log

# Backup archives created by gald3r_install on upgrade
*.zip

# Machine-specific config (paths, identity)
.vault_location
.user_id

# Temp/scratch files
*.tmp

# GitHub repo tracking files — user-specific, belong in vault when vault_location is configured (T034)
repos/
repos.txt
repo_tracker.json

# linking/ is deliberately source-controlled (topology config, not secrets)
# INBOX.md, link_topology.md, peers/ are all tracked

# v2 subfolder structure (all are working files, not source code)
# config/, docs/, tracking/, subsystems/ are created by gald3r_install
# and contain project-specific data that should not be committed in the source repo
