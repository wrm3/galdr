# Docker build context filter
# Build context is project root (for template access)
# Only include what the Dockerfile actually needs

# Exclude everything by default
*

# Include only what the build needs
!docker/requirements.txt
!docker/pyproject.toml
!docker/galdr/
!docker/galdr_video_analyzer/
!docker/entrypoint.sh
!docker/init_db/

# Templates (baked into image for galdr_install)
!templates/
!templates/**
