# galdr - Public Repository .gitignore
# Managed by galdr v1.0.0 - https://github.com/wrm3/galdr


# ============================================================
# Environment and secrets
# ============================================================
.env
*.env.local

# Machine-specific MCP config
.mcp.json


# ============================================================
# .galdr/ — task management data
# ============================================================
# The .galdr/ folder contains project-specific task tracking data.
# In the SOURCE REPO (this repo), .galdr/ is local only and not committed.
# Consumer projects may choose to commit .galdr/ selectively.
.galdr/

# galdr template (root-level copy)
.galdr_template/


# ============================================================
# Generated / runtime (not source)
# ============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
*.egg-info/
dist/
build/
uv.lock

# Rust / Tauri
target/
Cargo.lock

# Node
node_modules/
package-lock.json

# IDE internals
.vscode/
.idea/
*.swp
*.swo
*~

# galdr backup archives
.GALDR_backup_*.zip

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Docker volumes
postgres_data/

# Logs
*.log
logs/

# Platform docs (generated by crawl4ai, not tracked)
.platforms/

# Worktrees (parallel agent execution)
worktrees/

# Scripts (host-side automation, may contain local paths)
# Force-add individual scripts with: git add -f scripts/filename.ps1
/scripts/

# Research and temp (not tracked in public repo)
research/

# Temp folders (placeholder only, .gitkeep is tracked)
temp_docs/*
!temp_docs/.gitkeep
temp_scripts/*
!temp_scripts/.gitkeep
