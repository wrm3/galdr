# galdr - Public Repository .gitignore
# Managed by galdr v1.0.0 - https://github.com/wrm3/galdr


# ============================================================
# Environment and secrets
# ============================================================
.env
*.env.local

# Machine-specific MCP config (generated per-install, not source)
/.mcp.json


# ============================================================
# Generated / runtime (not source)
# ============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
*.egg-info/
dist/
build/
uv.lock

# Rust / Tauri
target/
Cargo.lock

# Node
node_modules/
package-lock.json

# IDE internals
.vscode/
.idea/
*.swp
*.swo
*~

# galdr backup archives
.GALDR_backup_*.zip

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Docker volumes
postgres_data/

# Logs
*.log
logs/

# Platform docs (generated by crawl4ai, not tracked)
.platforms/

# Worktrees (parallel agent execution)
worktrees/

# Scripts (host-side automation, may contain local paths)
# Force-add individual scripts with: git add -f scripts/filename.ps1
/scripts/

# Research and temp (not tracked in public repo)
research/

# Temp scripts (placeholder only, .gitkeep is tracked)
temp_scripts/*
!temp_scripts/.gitkeep

# Cursor continual-learning state (machine-specific, not source)
.cursor/hooks/state/continual-learning.json
.cursor/hooks/state/continual-learning-index.json

# galdr live session logs (generated per-session, not starter content)
.galdr/logs/*.log
!.galdr/logs/.gitkeep
