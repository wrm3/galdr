# galdr - Public Repository .gitignore
#
# IMPORTANT: These files are gitignored but NOT cursorignored.
# The AI agents read them from the filesystem and must obey the rules within.
# Git just doesn't track them because they contain personal/machine-specific content.

# ============================================================
# Personal IDE configurations (contain user-specific paths, keys, preferences)
# The templates/ folder IS tracked — it has clean {placeholder} versions.
# ============================================================
/.agent/
/.claude/
/.codex/
/.cursor/
/.opencode/

# ============================================================
# Project-local personality & fandom (NOT synced, NOT propagated)
# These are opt-in per-project. galdr ships norse_personality by default.
# Projects can swap in their own personality rule + fandom skill.
# Listed here so they exist in the working tree but never hit git.
# ============================================================
# Personality rules (only one active at a time; norse is the default)
.cursor/rules/silicon_valley_personality.mdc
.claude/rules/silicon_valley_personality.md
.agent/rules/silicon_valley_personality.md
.codex/rules/silicon_valley_personality.md
# Fandom skills
.cursor/skills/silicon-valley-superfan/
.claude/skills/silicon-valley-superfan/
.agent/skills/silicon-valley-superfan/
.codex/skills/silicon-valley-superfan/

# galdr project data (live project state, not template)
/.galdr/

# galdr template (root-level copy, identical to templates/.galdr_template/)
/.galdr_template/

# Root-level docs that get personalized per-user
/AGENTS.md
/CLAUDE.md
/GEMINI.md
/GUARDRAILS.md

# Cursor/IDE machine-specific
/.mcp.json
/.cursorignore

# ============================================================
# Environment and secrets
# ============================================================
.env
*.env.local

# ============================================================
# Generated / runtime (not source)
# ============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
*.egg-info/
dist/
build/
uv.lock

# Rust / Tauri
target/
Cargo.lock

# Node
node_modules/
package-lock.json

# IDE internals
.vscode/
.idea/
*.swp
*.swo
*~

# galdr backup archives
.GALDR_backup_*.zip

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Docker volumes
postgres_data/

# Research and temp (not tracked in public repo)
research/
temp_scripts/
temp_docs/

# Logs
*.log
logs/

# Platform docs (generated by crawl4ai, not tracked)
.platforms/

# Worktrees (parallel agent execution)
worktrees/

# Scripts (host-side automation, may contain local paths)
scripts/

research/