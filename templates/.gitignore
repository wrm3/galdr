# <!-- galdr GITIGNORE SECTION -->
# galdr system — managed patterns (do not edit between these markers)
# These entries are required for galdr to function safely.
# On upgrade, only this section is updated; your custom entries are preserved.

# Environment and secrets
.env
*.env.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
*.egg-info/
dist/
build/

# Node
node_modules/
package-lock.json

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Cursor machine-specific
.cursor/mcp.json

# galdr runtime state (per-machine, not tracked)
.galdr/state/
.galdr/logs/
.galdr/vault/

# galdr backup archives
.GALDR_backup_*.zip

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Platform docs (generated by crawl4ai, not tracked)
.platforms/

# Worktrees (parallel agent execution)
worktrees/

# Logs
*.log
logs/
# <!-- END galdr GITIGNORE SECTION -->
