# .galdr/.gitignore — galdr system local files
# This file is safe to overwrite on upgrades; it covers only the .galdr/ subtree.

# Hook-generated logs (audit, shell commands, reflection hints)
logs/
*.log

# Backup archives created by galdr_install on upgrade
*.zip

# Machine-specific config (paths, identity)
.vault_location
.user_id

# Temp/scratch files
*.tmp

# v2 subfolder structure (all are working files, not source code)
# config/, docs/, tracking/, subsystems/ are created by galdr_install
# and contain project-specific data that should not be committed in the source repo
